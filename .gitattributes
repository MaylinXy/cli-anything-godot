# Normalize line endings to LF in the repo for all text files.
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.gd    text eol=lf
*.cfg   text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.tscn  text eol=lf
*.tres  text eol=lf

# Binary (never normalize)
*.png   binary
*.jpg   binary
*.ico   binary
*.gif   binary
*.wav   binary
*.ogg   binary
